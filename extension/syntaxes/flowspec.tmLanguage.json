{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FlowSpec",
  "scopeName": "source.flowspec",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.flowspec",
          "match": "//.*$"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "entity.name.section.flowspec",
          "match": "^\\s*(Machine|Given|Assume|State|Messages|Initially|Move|Bad state|Always|Eventually|Fairness):"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flowspec",
          "match": "\\b(if|then|otherwise|same|for|some|every|no|has|in|is|not|and|or|per|one|of|a|set|collection|table|from|to|record|map|weak|strong)\\b"
        },
        {
          "name": "keyword.operator.word.flowspec",
          "match": "\\b(becomes|stays|gains|plus|except|intersects)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.flowspec",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.other.enum.flowspec",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.flowspec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.flowspec",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.flowspec",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.flowspec",
          "match": "(=>|!=|<=|>=|=|<|>|->|\\+|-|\\*|/)"
        }
      ]
    }
  }
}
